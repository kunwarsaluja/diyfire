{
  "definitions": [
    {
      "title": "Related Articles",
      "id": "related-articles",
      "model": "related-articles",
      "plugins": {
        "da": {
          "name": "related-articles",
          "rows": 2,
          "columns": 2,
          "fields": [
            { "name": "links", "selector": "div:nth-child(1)>div:nth-child(1)>ul" },
            { "name": "keywords", "selector": "div:nth-child(1)>div:nth-child(2)" },
            { "name": "excluded-keywords", "selector": "div:nth-child(2)>div:nth-child(2)" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "related-articles",
      "fields": [
        {
          "component": "richtext",
          "name": "links",
          "label": "Article Links",
          "valueType": "string",
          "description": "A list of links to specific articles. When present, block uses links mode; otherwise uses keywords."
        },
        {
          "component": "text",
          "name": "keywords",
          "label": "Keywords",
          "valueType": "string",
          "description": "Comma-separated keywords to match articles (e.g. fire, tfsa, rrsp). Use 'random' for random articles. Used when no links are authored."
        },
        {
          "component": "text",
          "name": "excluded-keywords",
          "label": "Excluded Keywords",
          "valueType": "string",
          "description": "Comma-separated keywords to exclude (e.g. external)"
        }
      ]
    }
  ],
  "filters": []
}
